# ─── Server ───
NODE_ENV=production
PORT=5000

# ─── MongoDB Atlas ───
# NOTE: If your password has special chars like @ # % → URL-encode them: @ → %40
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/healhub?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT ───
JWT_SECRET=your_jwt_secret_here_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_me
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ─── Frontend URL ───
# For local dev:  http://localhost:3000
# For Render:     https://your-app.onrender.com
FRONTEND_URL=http://localhost:3000

# ─── Optional: Gemini AI (for AI Assistant & Report Analyzer) ───
# GEMINI_API_KEY=your_gemini_api_key

# ─── Optional: Email (nodemailer) ───
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=your_app_password

